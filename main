# main.py
from asistente import AsistenteQuizAnimales

def main():
    try:
        # Instanciamos nuestro asistente de animales
        bot_quiz = AsistenteQuizAnimales()
        print("¡Bienvenido al sistema de Quiz de Razas de Animales!")
        print("=" * 50)
        
        # El bot inicia el juego con la primera pregunta
        respuesta_bot = bot_quiz.preguntar("¡Hola! Quiero jugar. Hazme la primera pregunta de la trivia.")
        print(f"\nBot: {respuesta_bot}")
        
        # Bucle interactivo para jugar en vivo desde la terminal
        while True:
            # Captura lo que escribas en la consola
            tu_respuesta = input("\nTu respuesta (o escribe 'salir' para terminar): ")
            
            # Condición de salida por si te cansas de jugar
            if tu_respuesta.strip().lower() in ["salir", "exit", "quit"]:
                print("\n¡Gracias por jugar! Trivia finalizada.")
                break
            
            # Si el usuario no escribe nada, evitar enviar mensajes vacíos
            if not tu_respuesta.strip():
                continue
                
            # Enviamos tu respuesta a la IA y ella nos dará el feedback y la siguiente pregunta
            respuesta_bot = bot_quiz.preguntar(tu_respuesta)
            print(f"\nBot: {respuesta_bot}")

    except ValueError as e:
        print(e)

if __name__ == "__main__":
    main()
